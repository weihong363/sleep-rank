page {
  background: #252847;
}

.screen {
  position: relative;
  width: 100vw;
  min-height: 100vh;
  padding: 88rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 62% 49%, rgba(255, 159, 96, 0.22), rgba(255, 159, 96, 0) 18%),
    radial-gradient(circle at 50% 51%, rgba(255, 218, 194, 0.08), rgba(255, 218, 194, 0) 20%),
    linear-gradient(180deg, #775a63 0%, #6e5560 28%, #544b67 52%, #2e2f50 78%, #252847 100%);
}

.screen-glow {
  position: absolute;
  inset: -20%;
  background: radial-gradient(circle at 50% 40%, rgba(255, 172, 116, 0.14), rgba(255, 172, 116, 0) 34%);
  pointer-events: none;
}

.content {
  position: relative;
  z-index: 1;
}

.page-title {
  text-align: center;
  margin-bottom: 22rpx;
  font-size: 48rpx;
  line-height: 1;
  letter-spacing: -1rpx;
  color: rgba(255, 236, 224, 0.92);
  text-transform: lowercase;
}

.card {
  border-radius: 26rpx;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(61, 58, 92, 0.72), rgba(44, 45, 77, 0.88));
  border: 1rpx solid rgba(255, 194, 154, 0.28);
  box-shadow:
    0 18rpx 40rpx rgba(12, 14, 34, 0.34),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.06);
}

.title {
  font-size: 32rpx;
  color: #ffe9d8;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.rank-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 191, 150, 0.18);
}

.rank-row:last-child {
  border-bottom: none;
}

.rank-no {
  width: 100rpx;
  color: #ffe2ca;
  font-weight: 600;
}

.rank-name {
  flex: 1;
  color: rgba(255, 237, 225, 0.9);
}

.rank-score {
  color: #ffcc9e;
  font-weight: 600;
}
