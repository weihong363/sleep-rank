<view class="screen {{isGlowing ? 'is-glowing' : ''}}">
  <view class="invite-banner" wx:if="{{hasPendingInvite}}" bindtap="onGoAcceptInvite">
    收到挑战邀请，点击接受
  </view>

  <view
    class="cloud-profile-banner"
    wx:if="{{!requireProfileComplete && requireCloudProfileSetup}}"
    bindtap="onGoCloudProfileSetup"
  >
    {{cloudProfileSetupText}}
  </view>

  <view class="profile-bar" wx:if="{{requireProfileComplete}}">
    <view class="profile-title">首次使用请先完善个人资料</view>
    <input
      class="profile-input"
      type="nickname"
      placeholder="请输入昵称"
      value="{{profileNickName}}"
      bindinput="onProfileNickInput"
    />
    <view class="profile-actions">
      <button class="profile-choose-btn" open-type="chooseAvatar" bindchooseavatar="onChooseProfileAvatar">
        {{profileAvatarUrl ? '已选择头像' : '选择头像'}}
      </button>
      <view class="profile-save-btn" bindtap="onSaveProfileFromHome">保存资料</view>
    </view>
  </view>

  <view
    class="button-wrap {{isSleeping ? 'is-sleeping' : ''}}"
    bindtap="handleTap"
  >
    <view class="button-halo"></view>

    <view
      wx:for="{{ripples}}"
      wx:key="id"
      class="ripple"
      style="width: {{item.size}}px; height: {{item.size}}px; left: {{item.left}}px; top: {{item.top}}px;"
    ></view>

    <view class="label">
      <text>{{labelTop}}</text>
      <text>{{labelBottom}}</text>
    </view>
  </view>

  <view class="entry-bar">
    <view class="entry-chip" bindtap="goCreateChallenge">挑战中心</view>
    <view class="entry-chip" bindtap="goCheckIn">我的记录</view>
    <view class="entry-chip" bindtap="goProfile">个人资料</view>
  </view>
</view>
