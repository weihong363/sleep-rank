.screen {
  position: relative;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background:
    radial-gradient(circle at 62% 49%, rgba(255, 159, 96, 0.22), rgba(255, 159, 96, 0) 18%),
    radial-gradient(circle at 50% 51%, rgba(255, 218, 194, 0.08), rgba(255, 218, 194, 0) 20%),
    linear-gradient(180deg, #775a63 0%, #6e5560 28%, #544b67 52%, #2e2f50 78%, #252847 100%);
}

.screen::after {
  content: '';
  position: absolute;
  inset: -20%;
  background: radial-gradient(circle at 50% 50%, rgba(255, 172, 116, 0.16), rgba(255, 172, 116, 0) 34%);
  opacity: 0;
  transform: scale(0.9);
  transition: opacity 0.55s ease, transform 0.55s ease;
  pointer-events: none;
}

.screen.is-glowing::after {
  opacity: 1;
  transform: scale(1.08);
}

.button-wrap {
  position: relative;
  width: 46vw;
  height: 46vw;
  max-width: 360rpx;
  max-height: 360rpx;
  min-width: 300rpx;
  min-height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0) 55%),
    linear-gradient(180deg, rgba(173, 135, 132, 0.92), rgba(142, 108, 109, 0.96));
  border: 1.5rpx solid rgba(255, 191, 150, 0.55);
  box-shadow:
    0 24rpx 40rpx rgba(12, 14, 34, 0.42),
    0 8rpx 16rpx rgba(0, 0, 0, 0.18),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.08),
    inset 0 -10rpx 18rpx rgba(80, 48, 54, 0.12);
  animation: breathe 3.6s ease-in-out infinite;
}

.button-wrap:active {
  transform: scale(0.97);
}

.button-halo {
  position: absolute;
  inset: -18rpx;
  border-radius: 9999rpx;
  background: radial-gradient(circle, rgba(255, 145, 85, 0.16), rgba(255, 145, 85, 0) 62%);
  filter: blur(10rpx);
  pointer-events: none;
}

.label {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #0e0b12;
  text-align: center;
  text-transform: lowercase;
  text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.04);
  transform: translateY(-2%);
  transition: opacity 0.28s ease, transform 0.28s ease;
}

.label text {
  display: block;
  font-size: 72rpx;
  font-weight: 400;
  line-height: 0.9;
  letter-spacing: -2rpx;
}

.button-wrap.is-sleeping .label {
  transform: translateY(-1%) scale(0.98);
  opacity: 0.92;
}

.ripple {
  position: absolute;
  z-index: 1;
  border-radius: 9999rpx;
  pointer-events: none;
  transform: scale(0);
  opacity: 1;
  background: radial-gradient(
    circle,
    rgba(255, 220, 180, 0.45) 0%,
    rgba(255, 170, 120, 0.25) 35%,
    rgba(255, 140, 90, 0.12) 55%,
    rgba(255, 140, 90, 0) 70%
  );
  filter: blur(1rpx);
  animation: ripple 0.7s ease-out forwards;
}

.invite-banner {
  position: absolute;
  top: 92rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 30;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  text-align: center;
  color: #2b1b22;
  font-weight: 600;
  background: linear-gradient(135deg, rgba(255, 210, 177, 0.95), rgba(255, 236, 197, 0.94));
  border: 1rpx solid rgba(255, 240, 227, 0.86);
  box-shadow: 0 10rpx 20rpx rgba(12, 14, 34, 0.32);
}

.entry-bar {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 58rpx;
  z-index: 5;
  display: flex;
  gap: 16rpx;
}

.entry-chip {
  flex: 1;
  height: 76rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 242, 232, 0.94);
  background: linear-gradient(
    180deg,
    rgba(58, 63, 102, 0.82) 0%,
    rgba(36, 40, 69, 0.7) 100%
  );
  border: 1rpx solid rgba(255, 227, 206, 0.22);
  box-shadow:
    0 10rpx 20rpx rgba(12, 14, 34, 0.34),
    0 2rpx 0 rgba(255, 246, 239, 0.18) inset,
    0 -2rpx 0 rgba(18, 21, 38, 0.2) inset;
}

.entry-chip:active {
  transform: scale(0.98);
}

@keyframes ripple {
  from {
    transform: scale(0);
    opacity: 1;
  }

  to {
    transform: scale(4);
    opacity: 0;
  }
}

@keyframes breathe {
  0%,
  100% {
    transform: scale(1);
    filter: brightness(1);
  }

  50% {
    transform: scale(1.018);
    filter: brightness(1.035);
  }
}
