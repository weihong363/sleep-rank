page {
  background: #252847;
}

.screen {
  position: relative;
  width: 100vw;
  min-height: 100vh;
  padding: 148rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 62% 49%, rgba(255, 159, 96, 0.22), rgba(255, 159, 96, 0) 18%),
    radial-gradient(circle at 50% 51%, rgba(255, 218, 194, 0.08), rgba(255, 218, 194, 0) 20%),
    linear-gradient(180deg, #775a63 0%, #6e5560 28%, #544b67 52%, #2e2f50 78%, #252847 100%);
}

.screen-glow {
  position: absolute;
  inset: -20%;
  background: radial-gradient(circle at 50% 40%, rgba(255, 172, 116, 0.14), rgba(255, 172, 116, 0) 34%);
  pointer-events: none;
}

.content {
  position: relative;
  z-index: 1;
}

.back-btn {
  position: absolute;
  top: 90rpx;
  left: 30rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.back-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 300;
  line-height: 1;
}

.page-title {
  text-align: center;
  margin-bottom: 20rpx;
  font-size: 44rpx;
  line-height: 1;
  letter-spacing: -1rpx;
  color: rgba(255, 236, 224, 0.92);
}

.card {
  border-radius: 26rpx;
  padding: 26rpx;
  background: linear-gradient(180deg, rgba(61, 58, 92, 0.72), rgba(44, 45, 77, 0.88));
  border: 1rpx solid rgba(255, 194, 154, 0.28);
  box-shadow:
    0 18rpx 40rpx rgba(12, 14, 34, 0.34),
    inset 0 1rpx 1rpx rgba(255, 255, 255, 0.06);
}

.title {
  font-size: 34rpx;
  color: #ffe9d8;
  font-weight: 600;
}

.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
}

.profile-info {
  flex: 1;
}

.nick-name {
  font-size: 36rpx;
  color: rgba(255, 236, 224, 0.96);
  font-weight: 600;
}

.line {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 233, 217, 0.92);
}

.field {
  margin-top: 20rpx;
}

.field-label {
  font-size: 26rpx;
  color: rgba(255, 224, 202, 0.88);
  margin-bottom: 10rpx;
}

.avatar-btn {
  width: 128rpx;
  min-width: 128rpx;
  max-width: 128rpx;
  height: 128rpx;
  min-height: 128rpx;
  max-height: 128rpx;
  border-radius: 20rpx;
  padding: 0;
  background: transparent;
  border: 1rpx solid rgba(255, 191, 150, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  line-height: 0;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  display: block;
}

.save-btn {
  margin-top: 20rpx;
  color: #0e0b12;
  border: none;
  border-radius: 9999rpx;
  background:
    radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0) 55%),
    linear-gradient(180deg, rgba(173, 135, 132, 0.95), rgba(142, 108, 109, 0.98));
}
