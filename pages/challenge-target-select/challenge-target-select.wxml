<view class="screen">
  <view class="screen-glow"></view>
  <view class="back-btn" bindtap="goBack">
    <text class="back-icon">‹</text>
  </view>
  <view class="content">
    <view class="page-title">选择用户或群组</view>

    <view class="tab-wrap">
      <view
        class="tab {{tab === 'USER' ? 'active' : ''}}"
        data-tab="USER"
        bindtap="switchTab"
      >
        用户
      </view>
      <view
        class="tab {{tab === 'GROUP' ? 'active' : ''}}"
        data-tab="GROUP"
        bindtap="switchTab"
      >
        群组
      </view>
    </view>

    <view class="card" wx:if="{{tab === 'USER'}}">
      <view
        class="item"
        wx:for="{{users}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="toggleUser"
      >
        <text>{{item.name}}</text>
        <text class="tag {{item.checked ? 'checked' : ''}}">
          {{item.checked ? '已选' : '选择'}}
        </text>
      </view>
    </view>

    <view class="card" wx:if="{{tab === 'GROUP'}}">
      <view
        class="item"
        wx:for="{{groups}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="toggleGroup"
      >
        <view class="group-info">
          <text class="group-name">{{item.name}}</text>
          <text class="group-members">成员 {{item.memberIds.length}} 人</text>
        </view>
        <view class="tag {{item.checked ? 'checked' : ''}}">
          <text>{{item.checked ? '已选' : '选择'}}</text>
        </view>
      </view>
    </view>

    <view class="footer">
      <text class="count">已选 {{selectedCount}} 人</text>
      <button class="confirm-btn" bindtap="confirmSelection">确定</button>
    </view>
  </view>
</view>
