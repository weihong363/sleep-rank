<view class="screen">
  <view class="screen-glow"></view>
  <view class="back-btn" bindtap="goBack">
    <text class="back-icon">‹</text>
  </view>
  <view class="content">
    <view class="page-title">挑战中心</view>

    <view class="card invite-card" wx:if="{{pendingInviteSummary}}">
      <view class="invite-owner">
        <image
          class="invite-owner-avatar"
          src="{{pendingInviteSummary.creatorAvatarUrl || '/images/default-avatar.svg'}}"
          mode="aspectFill"
        ></image>
        <view class="invite-owner-meta">
          <view class="invite-owner-name">{{pendingInviteSummary.creatorName}}</view>
          <view class="invite-owner-sub">邀请你加入睡眠挑战</view>
        </view>
      </view>
      <view class="invite-head">
        <view class="title">挑战邀请</view>
        <view class="invite-entry-tag" wx:if="{{fromInviteEntry}}">来自分享</view>
      </view>
      <view class="line">挑战：{{pendingInviteSummary.name}}</view>
      <view class="line">天数：{{pendingInviteSummary.targetDays}} 天</view>
      <view class="line">睡眠时间：{{pendingInviteSummary.sleepWindowText}}</view>
      <view class="line">当前状态：{{pendingInviteSummary.statusText}}</view>
      <view class="line">你的状态：{{pendingInviteSummary.meAcceptText}}</view>
      <view class="invite-tip-box">
        <view class="invite-tip">1. 接受后将加入本次组队挑战</view>
        <view class="invite-tip">2. 满 {{pendingInviteSummary.requiredCount}} 人确认后自动开赛</view>
      </view>
      <button class="create-btn" bindtap="onAcceptInvite">接受挑战</button>
      <button class="sub-btn" bindtap="onLaterDealInvite">稍后处理</button>
    </view>

    <view class="card" wx:if="{{showCreateCard}}">
      <view class="title">创建睡眠挑战</view>

      <view class="field">
        <view class="field-label">挑战名称</view>
        <input
          class="input"
          placeholder="例如：早睡早起挑战"
          placeholder-class="placeholder"
          value="{{challengeName}}"
          bindinput="onNameInput"
        />
      </view>

      <view class="field">
        <view class="field-label">挑战天数</view>
        <picker
          mode="selector"
          range="{{dayOptions}}"
          value="{{dayOptionIndex}}"
          bindchange="onDayChange"
        >
          <view class="picker-value">{{dayOptions[dayOptionIndex]}} 天</view>
        </picker>
      </view>

      <view class="field">
        <view class="field-label">睡眠时间窗口</view>
        <view class="window-row">
          <picker
            mode="selector"
            range="{{timeOptions}}"
            value="{{sleepStartIndex}}"
            bindchange="onSleepStartChange"
          >
            <view class="picker-value small">{{timeOptions[sleepStartIndex]}}</view>
          </picker>
          <text class="window-sep">至</text>
          <picker
            mode="selector"
            range="{{timeOptions}}"
            value="{{sleepEndIndex}}"
            bindchange="onSleepEndChange"
          >
            <view class="picker-value small">{{timeOptions[sleepEndIndex]}}</view>
          </picker>
        </view>
      </view>

      <view class="field">
        <view class="field-label">邀请方式</view>
        <view class="participant-preview">
          <text>创建后通过微信“分享”邀请好友或群成员加入</text>
        </view>
      </view>
    </view>

    <button
      wx:if="{{showCreateCard}}"
      class="create-btn"
      bindtap="onCreateTap"
    >
      创建挑战
    </button>

    <view class="card active-card" wx:if="{{!showCreateCard && activeSummary}}">
      <view class="title">正在挑战</view>
      <view class="line">挑战名称：{{activeSummary.name}}</view>
      <view class="line">挑战天数：{{activeSummary.targetDays}} 天</view>
      <view class="line">睡眠时间：{{activeSummary.sleepWindowText}}</view>
      <view class="line">挑战状态：{{activeSummary.statusText}}</view>
      <view class="line">开赛人数：{{activeSummary.confirmedCount}} / {{activeSummary.requiredCount}}</view>
      <view class="line" wx:if="{{activeSummary.startDateText !== '--'}}">
        开始时间：{{activeSummary.startDateText}}
      </view>

      <view class="participant-title">参与人</view>
      <view
        class="participant-row"
        wx:for="{{activeSummary.participants}}"
        wx:key="userId"
      >
        <text>{{item.name}}</text>
        <view class="accept-tag {{item.accepted ? 'ok' : 'pending'}}">
          <text>{{item.acceptText}}</text>
        </view>
      </view>

      <view class="field" wx:if="{{activeSummary.canInviteMore}}">
        <view class="field-label">继续邀请成员</view>
        <view class="participant-preview">
          <text>点击下方按钮，分享给好友或群组</text>
        </view>
        <button class="sub-btn" open-type="share">分享邀请</button>
      </view>

      <button
        wx:if="{{canCancel}}"
        class="cancel-btn"
        bindtap="onCancelChallenge"
      >
        取消挑战
      </button>
    </view>
  </view>
</view>
